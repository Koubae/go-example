{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
    
        {
            "name": "Run Package",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${fileDirname}",
             "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Identity",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/identity/main.go",
            "cwd": "${workspaceFolder}",

             "console": "integratedTerminal"
        },
        {
            "name": "Test: Current File",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
             // "args": ["-test.v", "&&", "sleep", "5000"],
             "args": ["-test.v"],
              "console": "integratedTerminal",
            "showLog": true,
            "trace": "verbose"
        }
    ]
}
